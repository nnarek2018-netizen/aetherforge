{
  "name": "aetherforge",
  "version": "1.0.0",
  "description": "Cyber-dark AI desktop client powered by local Ollama models",
  "author": "Aetherforge",
  "main": "dist/main.js",
  "scripts": {
    "build":  "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json",
    "start":  "npm run build && electron .",
    "dev":    "npm run build && electron . --inspect",
    "dist":   "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.aetherforge.desktop",
    "productName": "Aetherforge",
    "copyright": "Aetherforge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to":   "backend"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "signingHashAlgorithms": [],
      "sign": null
    },
    "nsis": {
      "oneClick":                      false,
      "perMachine":                    false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall":      false,
      "createDesktopShortcut":         true,
      "createStartMenuShortcut":       true,
      "shortcutName":                  "Aetherforge"
    }
  },
  "devDependencies": {
    "@types/node":      "^20.0.0",
    "electron":         "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript":       "^5.0.0"
  }
}
