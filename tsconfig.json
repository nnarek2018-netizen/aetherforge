{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "commonjs",
    "lib":             ["ES2020"],
    "outDir":          "dist",
    "rootDir":         "src",
    "strict":          true,
    "skipLibCheck":    true,
    "esModuleInterop": true,
    "sourceMap":       false
  },
  "include": ["src/main.ts", "src/preload.ts"],
  "exclude": ["node_modules", "dist", "src/renderer.ts"]
}
