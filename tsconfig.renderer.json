{
  "compilerOptions": {
    "target":       "ES2020",
    "module":       "none",
    "lib":          ["ES2020", "DOM"],
    "outDir":       "dist",
    "rootDir":      "src",
    "strict":       true,
    "skipLibCheck": true,
    "sourceMap":    false
  },
  "include": ["src/renderer.ts"],
  "exclude": ["node_modules", "dist"]
}
